# Host node_modules holds x64 binaries that would poison the arm64 image; reinstalled in-image.
node_modules

.git
.gitignore

# Env is supplied at runtime via compose env_file, not baked into the image.
.env
.env.example
.env.prod

# Logs / editor / tooling noise, irrelevant to the build.
logs
*.log
.vscode
.idea
.DS_Store
.pnpm-store
.claude

# Local docs and scratch files.
*.md
*.txt
