# Weather location (latitude, longitude, display name)
VITE_WEATHER_LAT=40.7128
VITE_WEATHER_LON=-74.006
VITE_WEATHER_NAME=New York
VITE_WEATHER_TIMEZONE=America/New_York

# Server ports
SERVER_PORT=5173
RTSP_PORT=554
WS_DISCOVERY_PORT=3702

# Streaming settings
FRAME_RATE=5
REFRESH_INTERVAL=600000

# ONVIF configuration
ONVIF_HOST=0.0.0.0
ONVIF_ADVERTISED_HOST=host.docker.internal
ONVIF_DEVICE_NAME=Weather Dashboard Camera

# ONVIF/RTSP credentials (required by UniFi Protect for third-party cameras)
ONVIF_USERNAME=admin
ONVIF_PASSWORD=weatherdash
