NODE_ENV=development

# Vite frontend app server
APP_PORT=5173

# RTSP server
RTSP_PORT=554
RTSP_PATH=/weather

# ONVIF server
ONVIF_PORT=8020
DEVICE_HOSTNAME=192.168.0.X

# Device identity
DEVICE_MAC=8D:FA:C6:EC:EB:E3
DEVICE_UUID=3150059e-4122-4416-9f69-19a2e477833c
DEVICE_MANUFACTURER=ViteCam
DEVICE_MODEL=Forecast

# Weather
VITE_WEATHER_LAT=40.7128
VITE_WEATHER_LON=-74.0060
VITE_WEATHER_NAME=New York
# Timezone used when formatting times in the UI (e.g. America/New_York).
# If empty, the browser's locale/timezone is used.
VITE_TIMEZONE=America/New_York
